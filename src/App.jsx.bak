import React, { useState, useEffect, useRef } from 'react';
import { motion, useScroll, useSpring, AnimatePresence, useTransform } from 'framer-motion';
import { 
  Github, 
  Linkedin, 
  Twitter, 
  ArrowRight, 
  Code, 
  ExternalLink, 
  Mail, 
  Send,
  Terminal,
  Layers,
  Zap,
  Palette,
